import pandas as pd
from prophet import Prophet
import matplotlib.pyplot as plt

# 1. 데이터 준비
# Prophet은 반드시 컬럼명을 'ds'(날짜)와 'y'(값)로 설정해야 합니다.
data = {
    'ds': pd.date_range(start='2023-01-01', periods=100, freq='D'),
    'y': [x + (x % 7) * 2 for x in range(100)] # 약간의 요일 패턴이 있는 가상 데이터
}
df = pd.DataFrame(data)

# 2. 모델 생성 및 학습
# yearly_seasonality, weekly_seasonality 등을 자동으로 감지하지만 명시할 수도 있습니다.
model = Prophet(daily_seasonality=True) 
model.fit(df)

# 3. 미래 날짜 프레임 생성
# 'periods'는 예측하고 싶은 기간(일수)입니다.
future = model.make_future_dataframe(periods=30)

# 4. 예측 수행
# forecast에는 예측값(yhat)뿐만 아니라 상한선(yhat_upper), 하한선(yhat_lower)도 포함됩니다.
forecast = model.predict(future)

# 5. 결과 시각화
# 검은 점은 실제 데이터, 파란 선은 예측값, 하늘색 영역은 신뢰 구간입니다.
fig1 = model.plot(forecast)
plt.title("Prophet Forecast")
plt.show()

# 6. 성분별 시각화 (Trend, Weekly, Daily 등)
fig2 = model.plot_components(forecast)
plt.show()
